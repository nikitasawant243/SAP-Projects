<mvc:View
    controllerName="demo.extend.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:custom="demo.extend.control"
    displayBlock="true">

    <App id="app1">
        <pages>
            <Page id="page1" title="Extending Standard Controls">
                <content>
                    <VBox id="vbox1" class="sapUiSmallMargin">
                        <Text id="txt1" text="Standard Button" />
                        <Button
                            id="btnNormal"
                            text="Normal Button"
                            press="onPressNormal"
                            class="sapUiSmallMarginBottom" />

                        <Text
                            id="txt2"
                            text="Extended Button"
                            class="sapUiSmallMarginTop" />

                        <custom:CustomButton
                            id="btnCustom"
                            text="Extended Button"
                            highlightColor="red"
                            press="onPressCustom" />
                    </VBox>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>