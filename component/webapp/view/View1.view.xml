<mvc:View
    controllerName="demo.component.component.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:custom="demo.component.component.control"
    displayBlock="true"
    id="view1">

    <App id="app1">
        <pages>
            <Page id="page1" title="Control Library Example">
                <content>
                    <VBox id="vbox1" class="sapUiSmallMargin">
                        <Text id="txtStandard" text="Standard Button" />
                        <Button id="btnStandard" text="Normal Button" />

                        <Text
                            id="txtLibrary"
                            text="Library Button"
                            class="sapUiSmallMarginTop" />

                        <custom:MyButton
                            id="btnLibrary"
                            customText="From Library" />
                    </VBox>
                </content>
            </Page>
        </pages>
    </App>
</mvc:View>