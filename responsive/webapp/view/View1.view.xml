<mvc:View
    controllerName="demo.responsive.responsive.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form">

    <Page title="Responsive Behavior">
        <content>
            <form:SimpleForm
                id="simpleForm"
                editable="true"
                layout="ResponsiveGridLayout"
                title="Employee Details"
                columnsXL="2"
                columnsL="2"
                columnsM="1">

                <Label text="First Name" />
                <Input value="{/firstName}" />

                <Label text="Last Name" />
                <Input value="{/lastName}" />

                <Label text="Email" />
                <Input value="{/email}" />

                <Label text="Mobile" />
                <Input value="{/mobile}" />

                <Label text="City" />
                <Input value="{/city}" />

                <Label text="Country" />
                <Input value="{/country}" />

            </form:SimpleForm>
        </content>
    </Page>
</mvc:View>